# Server Configuration
PORT=3000
NODE_ENV=development

# Database (if applicable)
# DATABASE_URL=your_database_url

# Blockchain Configuration
# RPC URL for the network where Vault is deployed (e.g., Base Testnet or Polygon Mumbai)
RPC_URL=https://sepolia.base.org

# Vault contract address (set after deployment)
VAULT_CONTRACT_ADDRESS=

# Private key for HUB server account (must have funds for gas fees)
# This account will call redeemVoucher on behalf of users
HUB_PRIVATE_KEY=your_hub_private_key_here

# API Keys
# API_KEY=your_api_key

