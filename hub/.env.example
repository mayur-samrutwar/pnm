# ============================================
# Hub Server Configuration - Multichain
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# Blockchain Configuration - Multichain
# ============================================

# Base Sepolia Configuration
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
VAULT_CONTRACT_ADDRESS_BASE_SEPOLIA=
CROSS_CHAIN_RECEIVER_ADDRESS_BASE_SEPOLIA=

# Ethereum Sepolia Configuration
ETHEREUM_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
VAULT_CONTRACT_ADDRESS_ETHEREUM_SEPOLIA=
CROSS_CHAIN_RECEIVER_ADDRESS_ETHEREUM_SEPOLIA=

# Legacy/Default (for backward compatibility)
RPC_URL=http://127.0.0.1:8545
VAULT_CONTRACT_ADDRESS=

# ============================================
# Hub Private Key
# ============================================
# Private key for HUB server account (must have funds for gas fees on ALL chains)
# This account will:
# - Call redeemVoucher on behalf of users
# - Withdraw from Vaults for bridging
# - Send cross-chain messages via Hyperlane
# Format: 0x followed by 64 hex characters (no spaces)
HUB_PRIVATE_KEY=0x354f0ee1fcac600f4fbd9f9c3b3495222743d05430884b4804c1c2cb093c75ea

# ============================================
# Token Addresses
# ============================================
# Native USDC addresses (from Hyperlane registry)
# Base Sepolia native USDC
NATIVE_USDC_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Ethereum Sepolia native USDC
NATIVE_USDC_ETHEREUM_SEPOLIA=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# Warp Route USDC addresses (from Hyperlane registry)
WARP_ROUTE_USDC_BASE_SEPOLIA=0x020dEE96414703c457322eed8504946583a7dd24
WARP_ROUTE_USDC_ETHEREUM_SEPOLIA=0x352f1c7ffa598d0698c1D8D2fCAb02511c6fF3e9

# Legacy (for backward compatibility)
MOCK_ERC20_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
USDC_ADDRESS=

# ============================================
# Hyperlane Configuration
# ============================================
# Hyperlane Mailbox addresses (get from Hyperlane docs)
# These are the Mailbox contract addresses on each chain
HYPERLANE_MAILBOX_ADDRESS_BASE_SEPOLIA=
HYPERLANE_MAILBOX_ADDRESS_ETHEREUM_SEPOLIA=
# Default (if chain-specific not set)
HYPERLANE_MAILBOX_ADDRESS=

# ============================================
# Redemption Configuration
# ============================================
# Enable automatic on-chain redemption when merchant redeems vouchers
# When true: hub will call vault.redeemVoucher() to transfer tokens to merchant
# When false: hub only marks voucher as used in database (tokens stay in vault)
REDEEM_ON_CHAIN=true

# ============================================
# API Keys (optional)
# ============================================
# API_KEY=your_api_key
