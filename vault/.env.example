# ============================================
# Multichain Deployment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ============================================
# Network RPC URLs
# ============================================
# Default RPC URL (used if network-specific URL not set)
RPC_URL=http://127.0.0.1:8545

# Base Sepolia Testnet
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Alternative: https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Ethereum Sepolia Testnet
ETHEREUM_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# Alternative: https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Other networks (optional)
BASE_TESTNET_RPC_URL=https://sepolia.base.org
POLYGON_MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID

# ============================================
# Private Keys (NEVER commit these!)
# ============================================
# Required for deployment - must have sufficient balance for gas fees
# Format: 0x followed by 64 hex characters (no spaces)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ============================================
# Hub Address (for CrossChainReceiver)
# ============================================
# This is the hub's address that will be authorized to send cross-chain messages
# Set this to your hub's address on the OPPOSITE chain:
# - For Base Sepolia receiver: use hub's Ethereum Sepolia address
# - For Ethereum Sepolia receiver: use hub's Base Sepolia address
# You may need to deploy twice: once to get addresses, then redeploy with correct addresses
HUB_ADDRESS=0x0000000000000000000000000000000000000000

# ============================================
# Deployed Contract Addresses
# ============================================
# Set these after deploying contracts

# Base Sepolia
VAULT_CONTRACT_ADDRESS_BASE_SEPOLIA=
CROSS_CHAIN_RECEIVER_ADDRESS_BASE_SEPOLIA=

# Ethereum Sepolia
VAULT_CONTRACT_ADDRESS_ETHEREUM_SEPOLIA=
CROSS_CHAIN_RECEIVER_ADDRESS_ETHEREUM_SEPOLIA=

# Legacy (for backward compatibility)
VAULT_CONTRACT_ADDRESS=

# ============================================
# Etherscan API Keys (for contract verification)
# ============================================
ETHERSCAN_API_KEY=your_etherscan_api_key
BASESCAN_API_KEY=your_basescan_api_key

# ============================================
# Gas Reporter (optional)
# ============================================
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key
